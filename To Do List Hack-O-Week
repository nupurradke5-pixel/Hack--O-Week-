<!doctype html>
<html lang="en" class="h-full">
 <head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Daily Routine Tracker</title>
  <script src="https://cdn.tailwindcss.com/3.4.17"></script>
  <script src="/_sdk/element_sdk.js"></script>
  <script src="/_sdk/data_sdk.js"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600;700&amp;display=swap" rel="stylesheet">
  <style>
    * { font-family: 'DM Sans', sans-serif; }
    .task-item { transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1); }
    .task-item:hover { transform: translateX(4px); }
    .task-item.completed .task-text { text-decoration: line-through; opacity: 0.6; }
    .checkbox-custom { transition: all 0.2s ease; }
    .checkbox-custom:hover { transform: scale(1.1); }
    .category-btn { transition: all 0.2s ease; }
    .category-btn:hover { transform: translateY(-2px); }
    .add-btn { transition: all 0.2s ease; }
    .add-btn:hover { transform: scale(1.02); box-shadow: 0 8px 25px -5px rgba(99, 102, 241, 0.4); }
    .delete-btn { opacity: 0; transition: opacity 0.2s ease; }
    .task-item:hover .delete-btn { opacity: 1; }
    @keyframes slideIn { from { opacity: 0; transform: translateY(-10px); } to { opacity: 1; transform: translateY(0); } }
    .animate-slide-in { animation: slideIn 0.3s ease-out; }
    .progress-bar { transition: width 0.5s ease; }
  </style>
  <style>body { box-sizing: border-box; }</style>
 </head>
 <body class="h-full">
  <div id="app-container" class="h-full overflow-auto" style="background: linear-gradient(135deg, #1e1b4b 0%, #312e81 50%, #1e1b4b 100%);">
   <div class="w-full min-h-full p-6 md:p-8">
    <div class="max-w-2xl mx-auto"><!-- Header -->
     <header class="mb-8 text-center">
      <h1 id="app-title" class="text-3xl md:text-4xl font-bold text-white mb-2">Daily Routine</h1>
      <p id="greeting-text" class="text-indigo-200 text-lg">Stay organized, stay productive</p>
      <div class="mt-4 flex items-center justify-center gap-3"><span id="date-display" class="text-indigo-300 text-sm"></span>
      </div>
     </header><!-- Progress Section -->
     <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-4 mb-6">
      <div class="flex items-center justify-between mb-2"><span class="text-indigo-200 text-sm font-medium">Today's Progress</span> <span id="progress-text" class="text-white font-semibold">0/0 completed</span>
      </div>
      <div class="h-3 bg-indigo-900/50 rounded-full overflow-hidden">
       <div id="progress-bar" class="progress-bar h-full bg-gradient-to-r from-emerald-400 to-cyan-400 rounded-full" style="width: 0%"></div>
      </div>
     </div><!-- Add Task Section -->
     <div class="bg-white/10 backdrop-blur-sm rounded-2xl p-5 mb-6">
      <div class="flex flex-col gap-4"><input type="text" id="task-input" placeholder="What's on your routine today?" class="w-full px-4 py-3 bg-white/10 border border-indigo-400/30 rounded-xl text-white placeholder-indigo-300 focus:outline-none focus:border-indigo-400 focus:ring-2 focus:ring-indigo-400/20">
       <div class="flex flex-wrap gap-2"><button data-category="morning" class="category-btn px-4 py-2 rounded-lg text-sm font-medium bg-amber-500/20 text-amber-300 border border-amber-500/30 hover:bg-amber-500/30">🌅 Morning</button> <button data-category="work" class="category-btn px-4 py-2 rounded-lg text-sm font-medium bg-blue-500/20 text-blue-300 border border-blue-500/30 hover:bg-blue-500/30">💼 Work</button> <button data-category="health" class="category-btn px-4 py-2 rounded-lg text-sm font-medium bg-emerald-500/20 text-emerald-300 border border-emerald-500/30 hover:bg-emerald-500/30">💪 Health</button> <button data-category="evening" class="category-btn px-4 py-2 rounded-lg text-sm font-medium bg-purple-500/20 text-purple-300 border border-purple-500/30 hover:bg-purple-500/30">🌙 Evening</button>
       </div><button id="add-btn" class="add-btn w-full py-3 bg-gradient-to-r from-indigo-500 to-purple-500 text-white font-semibold rounded-xl shadow-lg"> <span id="add-btn-text">+ Add Task</span> </button>
      </div>
      <p id="limit-warning" class="hidden mt-3 text-amber-300 text-sm text-center">⚠️ Maximum 999 tasks reached. Please delete some tasks first.</p>
     </div><!-- Filter Tabs -->
     <div class="flex gap-2 mb-4 overflow-x-auto pb-2"><button data-filter="all" class="filter-btn px-4 py-2 rounded-lg text-sm font-medium bg-white/20 text-white">All</button> <button data-filter="active" class="filter-btn px-4 py-2 rounded-lg text-sm font-medium bg-white/5 text-indigo-300 hover:bg-white/10">Active</button> <button data-filter="completed" class="filter-btn px-4 py-2 rounded-lg text-sm font-medium bg-white/5 text-indigo-300 hover:bg-white/10">Completed</button>
     </div><!-- Tasks List -->
     <div id="tasks-container" class="space-y-3">
      <div id="empty-state" class="text-center py-12">
       <div class="text-5xl mb-4">
        📝
       </div>
       <p class="text-indigo-300 text-lg">No tasks yet</p>
       <p class="text-indigo-400 text-sm">Add your first routine task above</p>
      </div>
     </div>
    </div>
   </div>
  </div>
  <script>
    // Default configuration
    const defaultConfig = {
      app_title: 'Daily Routine',
      greeting_text: 'Stay organized, stay productive',
      background_color: '#1e1b4b',
      surface_color: 'rgba(255,255,255,0.1)',
      text_color: '#ffffff',
      primary_action_color: '#6366f1',
      secondary_action_color: '#a5b4fc',
      font_family: 'DM Sans',
      font_size: 16
    };

    let allTasks = [];
    let selectedCategory = 'morning';
    let currentFilter = 'all';
    let currentRecordCount = 0;

    // Set current date
    const dateDisplay = document.getElementById('date-display');
    const options = { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' };
    dateDisplay.textContent = new Date().toLocaleDateString('en-US', options);

    // Category selection
    document.querySelectorAll('[data-category]').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('[data-category]').forEach(b => {
          b.classList.remove('ring-2', 'ring-white/50');
        });
        btn.classList.add('ring-2', 'ring-white/50');
        selectedCategory = btn.dataset.category;
      });
    });

    // Select default category
    document.querySelector('[data-category="morning"]').classList.add('ring-2', 'ring-white/50');

    // Filter selection
    document.querySelectorAll('.filter-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        document.querySelectorAll('.filter-btn').forEach(b => {
          b.classList.remove('bg-white/20', 'text-white');
          b.classList.add('bg-white/5', 'text-indigo-300');
        });
        btn.classList.remove('bg-white/5', 'text-indigo-300');
        btn.classList.add('bg-white/20', 'text-white');
        currentFilter = btn.dataset.filter;
        renderTasks();
      });
    });

    // Add task
    const taskInput = document.getElementById('task-input');
    const addBtn = document.getElementById('add-btn');
    const addBtnText = document.getElementById('add-btn-text');
    const limitWarning = document.getElementById('limit-warning');

    async function addTask() {
      const text = taskInput.value.trim();
      if (!text) return;

      if (currentRecordCount >= 999) {
        limitWarning.classList.remove('hidden');
        return;
      }

      addBtn.disabled = true;
      addBtnText.textContent = 'Adding...';

      const result = await window.dataSdk.create({
        text: text,
        completed: false,
        category: selectedCategory,
        createdAt: new Date().toISOString()
      });

      addBtn.disabled = false;
      addBtnText.textContent = '+ Add Task';

      if (result.isOk) {
        taskInput.value = '';
        limitWarning.classList.add('hidden');
      } else {
        console.error('Failed to add task');
      }
    }

    addBtn.addEventListener('click', addTask);
    taskInput.addEventListener('keypress', (e) => {
      if (e.key === 'Enter') addTask();
    });

    // Toggle task completion
    async function toggleTask(task) {
      const updatedTask = { ...task, completed: !task.completed };
      const result = await window.dataSdk.update(updatedTask);
      if (result.isError) {
        console.error('Failed to update task');
      }
    }

    // Delete task with inline confirmation
    let pendingDelete = null;

    function requestDelete(task) {
      pendingDelete = task.__backendId;
      renderTasks();
    }

    function cancelDelete() {
      pendingDelete = null;
      renderTasks();
    }

    async function confirmDelete(task) {
      const result = await window.dataSdk.delete(task);
      if (result.isOk) {
        pendingDelete = null;
      } else {
        console.error('Failed to delete task');
      }
    }

    // Render tasks
    function renderTasks() {
      const container = document.getElementById('tasks-container');
      const emptyState = document.getElementById('empty-state');
      
      let filteredTasks = allTasks;
      if (currentFilter === 'active') {
        filteredTasks = allTasks.filter(t => !t.completed);
      } else if (currentFilter === 'completed') {
        filteredTasks = allTasks.filter(t => t.completed);
      }

      // Sort by creation date, newest first
      filteredTasks.sort((a, b) => new Date(b.createdAt) - new Date(a.createdAt));

      // Update progress
      const completed = allTasks.filter(t => t.completed).length;
      const total = allTasks.length;
      document.getElementById('progress-text').textContent = `${completed}/${total} completed`;
      const percentage = total > 0 ? (completed / total) * 100 : 0;
      document.getElementById('progress-bar').style.width = `${percentage}%`;

      // Check limit
      if (currentRecordCount >= 999) {
        limitWarning.classList.remove('hidden');
      } else {
        limitWarning.classList.add('hidden');
      }

      if (filteredTasks.length === 0) {
        emptyState.classList.remove('hidden');
        // Remove task items but keep empty state
        container.querySelectorAll('.task-item').forEach(el => el.remove());
        return;
      }

      emptyState.classList.add('hidden');

      const existingItems = new Map(
        [...container.querySelectorAll('.task-item')].map(el => [el.dataset.taskId, el])
      );

      const categoryStyles = {
        morning: { bg: 'bg-amber-500/20', border: 'border-amber-500/30', icon: '🌅' },
        work: { bg: 'bg-blue-500/20', border: 'border-blue-500/30', icon: '💼' },
        health: { bg: 'bg-emerald-500/20', border: 'border-emerald-500/30', icon: '💪' },
        evening: { bg: 'bg-purple-500/20', border: 'border-purple-500/30', icon: '🌙' }
      };

      filteredTasks.forEach(task => {
        const style = categoryStyles[task.category] || categoryStyles.morning;
        const isDeleting = pendingDelete === task.__backendId;

        if (existingItems.has(task.__backendId)) {
          const el = existingItems.get(task.__backendId);
          updateTaskElement(el, task, style, isDeleting);
          existingItems.delete(task.__backendId);
        } else {
          const el = createTaskElement(task, style, isDeleting);
          container.appendChild(el);
        }
      });

      existingItems.forEach(el => el.remove());
    }

    function createTaskElement(task, style, isDeleting) {
      const div = document.createElement('div');
      div.className = `task-item animate-slide-in ${style.bg} ${style.border} border rounded-xl p-4 ${task.completed ? 'completed' : ''}`;
      div.dataset.taskId = task.__backendId;
      updateTaskElementContent(div, task, style, isDeleting);
      return div;
    }

    function updateTaskElement(el, task, style, isDeleting) {
      el.className = `task-item ${style.bg} ${style.border} border rounded-xl p-4 ${task.completed ? 'completed' : ''}`;
      updateTaskElementContent(el, task, style, isDeleting);
    }

    function updateTaskElementContent(el, task, style, isDeleting) {
      el.innerHTML = `
        <div class="flex items-center gap-4">
          <button class="checkbox-custom w-6 h-6 rounded-full border-2 ${task.completed ? 'bg-emerald-500 border-emerald-500' : 'border-indigo-400'} flex items-center justify-center flex-shrink-0" onclick="toggleTaskById('${task.__backendId}')">
            ${task.completed ? '<svg class="w-4 h-4 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"></path></svg>' : ''}
          </button>
          <span class="text-xl">${style.icon}</span>
          <span class="task-text text-white flex-1">${escapeHtml(task.text)}</span>
          ${isDeleting ? `
            <div class="flex gap-2">
              <button class="px-3 py-1 bg-red-500 text-white text-sm rounded-lg hover:bg-red-600" onclick="confirmDeleteById('${task.__backendId}')">Delete</button>
              <button class="px-3 py-1 bg-white/20 text-white text-sm rounded-lg hover:bg-white/30" onclick="cancelDelete()">Cancel</button>
            </div>
          ` : `
            <button class="delete-btn p-2 text-indigo-300 hover:text-red-400 hover:bg-red-500/20 rounded-lg" onclick="requestDeleteById('${task.__backendId}')">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path></svg>
            </button>
          `}
        </div>
      `;
    }

    function escapeHtml(text) {
      const div = document.createElement('div');
      div.textContent = text;
      return div.innerHTML;
    }

    // Global functions for onclick handlers
    window.toggleTaskById = (id) => {
      const task = allTasks.find(t => t.__backendId === id);
      if (task) toggleTask(task);
    };

    window.requestDeleteById = (id) => {
      const task = allTasks.find(t => t.__backendId === id);
      if (task) requestDelete(task);
    };

    window.confirmDeleteById = (id) => {
      const task = allTasks.find(t => t.__backendId === id);
      if (task) confirmDelete(task);
    };

    window.cancelDelete = cancelDelete;

    // Data handler
    const dataHandler = {
      onDataChanged(data) {
        allTasks = data;
        currentRecordCount = data.length;
        renderTasks();
      }
    };

    // Element SDK config change handler
    async function onConfigChange(config) {
      const title = config.app_title || defaultConfig.app_title;
      const greeting = config.greeting_text || defaultConfig.greeting_text;
      const bgColor = config.background_color || defaultConfig.background_color;
      const textColor = config.text_color || defaultConfig.text_color;
      const fontFamily = config.font_family || defaultConfig.font_family;
      const fontSize = config.font_size || defaultConfig.font_size;

      document.getElementById('app-title').textContent = title;
      document.getElementById('greeting-text').textContent = greeting;
      
      document.getElementById('app-container').style.background = `linear-gradient(135deg, ${bgColor} 0%, ${adjustColor(bgColor, 30)} 50%, ${bgColor} 100%)`;
      
      document.getElementById('app-title').style.fontFamily = `${fontFamily}, sans-serif`;
      document.getElementById('app-title').style.fontSize = `${fontSize * 2}px`;
      document.getElementById('greeting-text').style.fontFamily = `${fontFamily}, sans-serif`;
      document.getElementById('greeting-text').style.fontSize = `${fontSize * 1.125}px`;
    }

    function adjustColor(hex, amount) {
      const num = parseInt(hex.replace('#', ''), 16);
      const r = Math.min(255, Math.max(0, (num >> 16) + amount));
      const g = Math.min(255, Math.max(0, ((num >> 8) & 0x00FF) + amount));
      const b = Math.min(255, Math.max(0, (num & 0x0000FF) + amount));
      return '#' + (1 << 24 | r << 16 | g << 8 | b).toString(16).slice(1);
    }

    // Initialize SDKs
    (async () => {
      if (window.elementSdk) {
        window.elementSdk.init({
          defaultConfig,
          onConfigChange,
          mapToCapabilities: (config) => ({
            recolorables: [
              {
                get: () => config.background_color || defaultConfig.background_color,
                set: (value) => { config.background_color = value; window.elementSdk.setConfig({ background_color: value }); }
              },
              {
                get: () => config.surface_color || defaultConfig.surface_color,
                set: (value) => { config.surface_color = value; window.elementSdk.setConfig({ surface_color: value }); }
              },
              {
                get: () => config.text_color || defaultConfig.text_color,
                set: (value) => { config.text_color = value; window.elementSdk.setConfig({ text_color: value }); }
              },
              {
                get: () => config.primary_action_color || defaultConfig.primary_action_color,
                set: (value) => { config.primary_action_color = value; window.elementSdk.setConfig({ primary_action_color: value }); }
              },
              {
                get: () => config.secondary_action_color || defaultConfig.secondary_action_color,
                set: (value) => { config.secondary_action_color = value; window.elementSdk.setConfig({ secondary_action_color: value }); }
              }
            ],
            borderables: [],
            fontEditable: {
              get: () => config.font_family || defaultConfig.font_family,
              set: (value) => { config.font_family = value; window.elementSdk.setConfig({ font_family: value }); }
            },
            fontSizeable: {
              get: () => config.font_size || defaultConfig.font_size,
              set: (value) => { config.font_size = value; window.elementSdk.setConfig({ font_size: value }); }
            }
          }),
          mapToEditPanelValues: (config) => new Map([
            ['app_title', config.app_title || defaultConfig.app_title],
            ['greeting_text', config.greeting_text || defaultConfig.greeting_text]
          ])
        });
      }

      if (window.dataSdk) {
        await window.dataSdk.init(dataHandler);
      }
    })();
  </script>
